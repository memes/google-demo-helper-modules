apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: ollama
  annotations:
    config.kubernetes.io/local-config: "true"
info:
  description: Deploys an Ollama container and service, with an asynchronous pull of model.
  emails:
    - m.emes@f5.com
  license: Apache-2.0
  keywords:
    - llm
    - ollama
pipeline:
  mutators:
    - image: gcr.io/kpt-fn/set-namespace:v0.4.1
      configPath: package-context.yaml
    - image: gcr.io/kpt-fn/apply-setters:v0.2.0
      configMap:
        gpu_count: "1"
        gpu_type: nvidia-tesla-t4
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: ollama/ollama
        newName: ollama/ollama
        tag: 0.6.4
  validators:
    - image: gcr.io/kpt-fn/kubeval:v0.3.0
      configMap:
        skip_kinds: Kustomization

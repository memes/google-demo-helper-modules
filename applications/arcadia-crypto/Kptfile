apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: arcadia-crypto
  annotations:
    config.kubernetes.io/local-config: "true"
info:
  description: |-
    Arcadia Crypto is an Arcadia Finance demo application that allows customers
    to trade cryptocurrencies and ask questions via a chat bot interface.
  emails:
    - m.emes@f5.com
  license: Apache-2.0
  keywords:
    - arcadia
    - crypto
    - chatbot
    - llm
    - genai
pipeline:
  mutators:
    - image: gcr.io/kpt-fn/set-namespace:v0.4.1
      configPath: package-context.yaml
    - image: gcr.io/kpt-fn/apply-setters:v0.2.0
      configMap:
        host: '*.f5demos.com'
        gpu_count: 1
        gpu_type: nvidia-tesla-t4
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: mongo
        newName: mongo
        tag: 8.0.6-noble
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: ollama/ollama
        newName: ollama/ollama
        tag: 0.6.4
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-ai
        newName: sorinboiaf5/arcadia-ai
        tag: v1
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-ai-rag
        newName: sorinboiaf5/arcadia-ai-rag
        tag: v1
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-frontend
        newName: sorinboiaf5/arcadia-frontend
        tag: v1
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-login
        newName: sorinboiaf5/arcadia-login
        tag: v1
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-stock_transaction
        newName: sorinboiaf5/arcadia-stock_transaction
        tag: v1
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-stocks
        newName: sorinboiaf5/arcadia-stocks
        tag: v1
    - image: gcr.io/kpt-fn/set-image:v0.1.1
      configMap:
        name: sorinboiaf5/arcadia-users
        newName: sorinboiaf5/arcadia-users
        tag: v1
  validators:
    - image: gcr.io/kpt-fn/kubeval:v0.3.0
      configMap:
        skip_kinds: Kustomization

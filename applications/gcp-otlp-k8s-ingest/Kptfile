apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: gcp-otlp-k8s-ingest
  annotations:
    config.kubernetes.io/local-config: "true"
info:
  description: |-
    Deploys Google Cloud's opinionated OTEL collector for GKE.
  emails:
    - m.emes@f5.com
  license: Apache-2.0
  keywords:
    - otel
    - gke
pipeline:
  mutators:
    - image: gcr.io/kpt-fn/set-namespace:v0.4.1
      configMap:
        namespace: opentelemetry
  validators:
    - image: gcr.io/kpt-fn/kubeval:v0.3.0

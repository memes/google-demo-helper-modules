apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: inference-pool
  annotations:
    config.kubernetes.io/local-config: "true"
info:
  description: |-
    Provides a package for deploying Inference Pool extension for Gateway
  emails:
    - m.emes@f5.com
  license: Apache-2.0
  keywords:
    - inference pool
    - inference gateway
pipeline:
  mutators:
    # Apply deployment specific values from apply-setters.yaml.
    - image: ghcr.io/kptdev/krm-functions-catalog/apply-setters@sha256:1d84fb5c0650036a2cebba76f7839b5fa30fa315a8104595e58c40485d678f38
      configPath: apply-setters.yaml
    # Render the Helm chart as manifest.
    - image: ghcr.io/krm-functions/render-helm-chart:latest
    # Remove resources that are annotated as local-config.
    - image: ghcr.io/kptdev/krm-functions-catalog/remove-local-config-resources@sha256:98bad344c6b13d5f3d23d00ca1cbea9639d13d506372923d22826a5589bb2e18
    # Modify the epp image if needed.
    - image: ghcr.io/kptdev/krm-functions-catalog/set-image:latest
      configMap:
        name: registry.k8s.io/gateway-api-inference-extension/epp
        newName: registry.k8s.io/gateway-api-inference-extension/epp
        newTag: v1.4.0
    # Remove resource labels that imply the deployment is managed by Helm.
    - image: ghcr.io/kptdev/krm-functions-catalog/starlark@sha256:bf378ebe32838ba1c0eb92c5551613d19dc40459f3e6cee405b957eb71287649
      configPath: label-cleanup.yaml
    # Reset the namespace of all resources to the value in package-context.yaml.
    - image: ghcr.io/kptdev/krm-functions-catalog/set-namespace@sha256:355a5cd15a4157165a7b0ab8f38150227fd00faa5ed21e400139dc50bb1a2cb1
      configPath: package-context.yaml
      # Add other local pipeline mutators as needed.
  validators:
    - image: ghcr.io/kptdev/krm-functions-catalog/kubeconform@sha256:80ce9eb3eec6b51e90a8da0e322d629139bc5f14f00404daac9c749bb58646e9
      configMap:
        strict: 'true'
